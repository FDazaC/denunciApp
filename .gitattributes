# 1. Manejo automático de finales de línea (LF para Linux, CRLF para Windows)
* text=auto

# 2. Forzar que archivos de código siempre usen LF (estándar en Linux/Ubuntu)
*.java      text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.json      text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.xml       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf

# 3. Marcar archivos de scripts como ejecutables y con LF
*.sh        text eol=lf
*.bash      text eol=lf

# 4. Evitar que Git intente "corregir" archivos binarios (imágenes, PDFs, etc.)
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.pdf       binary
*.ico       binary
*.jar       binary
*.war       binary

# 5. Configuración para Maven y Wrappers
mvnw        text eol=lf
*.cmd       text eol=crlf
*.bat       text eol=crlf
